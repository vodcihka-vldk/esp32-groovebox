  ;; USB-C Connector
  (footprint "Connector_USB:USB_C_Receptacle_HRO_TYPE-C-31-M-12" (layer "F.Cu")
    (tstamp usb-001)
    (at 20 50)
    (descr "USB Type-C receptacle for USB 2.0 and PD, http://www.king-hing.com/Uploads/enfile/20170413083903.pdf")
